}

.ugc-card__cover--home6 {
  background: #d4ccc0;
}

.ugc-card__badge {
  align-self: flex-start;
  margin: 20rpx 0 0 20rpx;
  padding: 6rpx 16rpx;
  font-size: 20rpx;
  color: #faf8f5;
  letter-spacing: 2rpx;
  background-color: rgba(44, 42, 40, 0.28);
  border-radius: 4rpx;
}

.ugc-card__stats {
  display: flex;
  flex-direction: row;
  align-items: center;
