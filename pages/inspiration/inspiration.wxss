page {
  background-color: #f7f6f2;
  height: 100%;
}

.inspiration-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f7f6f2;
  box-sizing: border-box;
}

.search-wrap {
  flex-shrink: 0;
  padding: 12rpx 24rpx 12rpx;
  background-color: #f7f6f2;
}

.search-wrap .van-search {
  padding: 0 !important;
}

.search-wrap .van-search__content {
  background-color: #ffffff !important;
  border: none !important;
}

.search-wrap .van-field__control {
  color: #2c2a28 !important;
  font-size: 28rpx !important;
}

.main-scroll {
  flex: 1;
  height: 0;
}

/* ========== 话题集：横向低矮专题卡 ========== */
.topic-section {
  padding: 16rpx 0 28rpx;
}

.topic-scroll {
  width: 100%;
  white-space: nowrap;
}

.topic-list {
  display: flex;
  flex-direction: row;
  padding-left: 24rpx;
  box-sizing: border-box;
}

.topic-card {
  flex-shrink: 0;
  width: 520rpx;
  height: 200rpx;
  margin-right: 20rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(44, 42, 40, 0.06);
  box-sizing: border-box;
}

.topic-card:last-child {
  margin-right: 32rpx;
}

.topic-card__thumb {
  flex-shrink: 0;
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.topic-card__thumb--t1 {
  background: linear-gradient(145deg, #e8e2d8 0%, #c9bfb0 100%);
}

.topic-card__thumb--t2 {
  background: linear-gradient(145deg, #e5ddd2 0%, #b8aa9a 100%);
}

.topic-card__thumb--t3 {
  background: linear-gradient(145deg, #ede8e0 0%, #cfc4b4 100%);
}

.topic-card__thumb--t4 {
  background: linear-gradient(145deg, #e0dad0 0%, #b5aa9c 100%);
}

.topic-card__thumb--t5 {
  background: linear-gradient(145deg, #ddd6cb 0%, #a6998d 100%);
}

.topic-card__thumb--t6 {
  background: linear-gradient(145deg, #e2dbd0 0%, #b0a596 100%);
}

.topic-card__info {
  flex: 1;
  min-width: 0;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.topic-card__title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2c2a28;
  line-height: 1.35;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.topic-card__meta {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #9a948a;
  line-height: 1.3;
}

.topic-card__desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #b0aaa0;
  line-height: 1.35;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

/* ========== 胶囊筛选器 ========== */
.filter-section {
  padding: 0 0 8rpx;
  background-color: #f7f6f2;
}

.capsule-scroll {
  width: 100%;
  white-space: nowrap;
}

.capsule-row {
  display: flex;
  flex-direction: row;
  padding: 0 24rpx 16rpx;
  box-sizing: border-box;
}

.capsule {
  flex-shrink: 0;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  padding: 0 28rpx;
  margin-right: 16rpx;
  border-radius: 32rpx;
  background-color: #eceae6;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.capsule--active {
  background-color: #ffffff;
  border-color: #2c2a28;
}

.capsule__text {
  font-size: 26rpx;
  color: #5a564f;
  white-space: nowrap;
}

.capsule--active .capsule__text {
  color: #2c2a28;
  font-weight: 600;
}

.capsule__arrow {
  margin-left: 6rpx;
  font-size: 22rpx;
  color: #8a8578;
  line-height: 1;
  transition: transform 0.28s ease;
}

.capsule--active .capsule__arrow {
  color: #2c2a28;
}

.capsule__arrow.is-up {
  transform: rotate(180deg);
}

/* ========== 下拉筛选面板 ========== */
.filter-panel {
  max-height: 0;
  opacity: 0;
  overflow: hidden;
  padding: 0 24rpx;
  transition: max-height 0.32s ease, opacity 0.28s ease, padding 0.28s ease;
  box-sizing: border-box;
}

.filter-panel.is-show {
  max-height: 480rpx;
  opacity: 1;
  padding: 0 24rpx 20rpx;
}

.filter-panel__inner {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(44, 42, 40, 0.05);
  box-sizing: border-box;
}

.filter-panel__tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.filter-tag {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 56rpx;
  padding: 0 24rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
  border-radius: 28rpx;
  background-color: #f3f1ed;
  box-sizing: border-box;
}

.filter-tag--active {
  background-color: #2c2a28;
}

.filter-tag__text {
  font-size: 24rpx;
  color: #5a564f;
  white-space: nowrap;
}

.filter-tag--active .filter-tag__text {
  color: #ffffff;
  font-weight: 500;
}

/* ========== 轻瀑布内容流 ========== */
.feed-section {
  padding: 12rpx 20rpx 0;
  box-sizing: border-box;
}

.feed-waterfall {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
}

.feed-col {
  width: calc(50% - 8rpx);
  display: flex;
  flex-direction: column;
}

.feed-card {
  width: 100%;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  background-color: transparent;
  box-sizing: border-box;
}

.feed-card__cover {
  width: 100%;
  border-radius: 20rpx;
  overflow: hidden;
  background-color: #ebe6df;
  box-shadow: 0 4rpx 20rpx rgba(44, 42, 40, 0.05);
}

.feed-card__cover-img {
  width: 100%;
  height: 100%;
  display: block;
}

.feed-card__cover-placeholder {
  width: 100%;
  height: 100%;
}

.feed-card__cover-placeholder--f1 {
  background-color: #e8e2d8;
}

.feed-card__cover-placeholder--f2 {
  background-color: #e5ddd2;
}

.feed-card__cover-placeholder--f3 {
  background-color: #e0dad0;
}

.feed-card__cover-placeholder--f4 {
  background-color: #ddd6cb;
}

.feed-card__cover-placeholder--f5 {
  background-color: #ede8e0;
}

.feed-card__cover-placeholder--f6 {
  background-color: #e2dbd0;
}

.feed-card__body {
  display: flex;
  flex-direction: column;
  padding: 16rpx 8rpx 8rpx;
  box-sizing: border-box;
}

.feed-card__title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2c2a28;
  line-height: 40rpx;
  letter-spacing: 0.5rpx;
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.feed-card__desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #9a948a;
  line-height: 34rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.feed-card__footer {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 14rpx;
  padding-top: 4rpx;
}

.feed-stat {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-right: 24rpx;
}

.feed-stat__num {
  margin-left: 6rpx;
  font-size: 22rpx;
  color: #9a948a;
  line-height: 1;
}

.page-bottom-spacer {
  height: calc(120rpx + env(safe-area-inset-bottom));
}
