page {
  background-color: #ffffff;
  height: 100%;
}

.profile-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #ffffff;
  box-sizing: border-box;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* ── 品牌欢迎区 ── */
.profile-welcome {
  flex-shrink: 0;
  height: 53vh;
  min-height: 720rpx;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #f5f1e8 0%, #f0ebe2 50%, #ebe5db 100%);
  box-sizing: border-box;
  overflow: hidden;
}

.profile-welcome__header {
  flex-shrink: 0;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  padding: 16rpx 40rpx 0 48rpx;
  box-sizing: border-box;
}

.profile-welcome__heading {
  flex: 1;
  min-width: 0;
  padding-top: 98rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  box-sizing: border-box;
}

.profile-welcome__service {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
}

.profile-welcome__line {
  display: block;
  width: 100%;
  text-align: left;
  font-size: 76rpx;
  font-weight: 600;
  color: #3e3128;
  line-height: 1.22;
  letter-spacing: 4rpx;
}

.profile-welcome__line--brand {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  margin-top: 24rpx;
}

.profile-welcome__text {
  font-size: 76rpx;
  font-weight: 600;
  color: #3e3128;
  line-height: 1.22;
  letter-spacing: 4rpx;
}

.profile-welcome__brand {
  font-size: 76rpx;
  font-weight: 600;
  color: #c69c6d;
  line-height: 1.22;
  letter-spacing: 4rpx;
  margin: 0 8rpx;
}

.profile-welcome__body {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: stretch;
  padding: 70rpx 48rpx 64rpx;
 
  box-sizing: border-box;
}

.profile-welcome__subtitle {
  display: block;
  width: 100%;
  text-align: left;
  margin-top: 45rpx;
  margin-left: 0;
  padding-left: 0;
  font-size: 28rpx;
  font-weight: 400;
  color: #8b7e74;
  line-height: 1.65;
  letter-spacing: 2rpx;
}

.profile-login-wrap {
  width: 100%;
  margin-top: 80rpx;
  display: flex;
  flex-direction: row;
  justify-content: center;
  flex-shrink: 0;
  box-sizing: border-box;
}

.profile-login-btn {
  width: 100%;
  height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ffffff;
  border-radius: 56rpx;
  box-shadow: 0 6rpx 28rpx rgba(62, 49, 40, 0.07);
  box-sizing: border-box;
  flex-shrink: 0;
}

.profile-login-btn__text {
  font-size: 32rpx;
  font-weight: 500;
  color: #3e3128;
  letter-spacing: 4rpx;
}

/* ── 功能列表 ── */
.profile-body {
  flex: 1;
  width: 100%;
  background-color: #ffffff;
  padding: 64rpx 0 80rpx;
  box-sizing: border-box;
}

.profile-list {
  width: 100%;
  box-sizing: border-box;
}

.profile-list__item {
  width: 100%;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 48rpx;
  box-sizing: border-box;
  border-bottom: 1rpx solid rgba(62, 49, 40, 0.08);
}

.profile-list__item:last-child {
  border-bottom: none;
}

.profile-list__title {
  font-size: 30rpx;
  font-weight: 400;
  color: #3e3128;
  letter-spacing: 1rpx;
}
