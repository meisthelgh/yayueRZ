}

.ugc-card__desc {
  font-size: 24rpx;
  color: #9a948a;
  line-height: 1.45;
  white-space: normal;
}

.home-bottom-spacer {
  height: calc(120rpx + env(safe-area-inset-bottom));
}

.guess-section {
  padding: 56rpx 0 0;
  box-sizing: border-box;
  background-color: #f0eeeb;
}

.guess-head {
  padding: 0 24rpx 8rpx;
}

.guess-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #2c2a28;
  letter-spacing: 2rpx;
}

.guess-tabs {
  --tabs-bottom-bar-color: #6b6458;
  --tab-font-size: 26rpx;
}

.guess-section .van-tabs__wrap {
  background-color: #f0eeeb !important;
}

.guess-section .van-tabs__nav {
  background-color: #f0eeeb !important;
}

.guess-section .van-tab {
  font-size: 26rpx !important;
  padding: 0 20rpx !important;
}

.guess-section .van-tab--active {
  font-weight: 600 !important;
}

.guess-feed {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: space-between;
  align-content: flex-start;
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
}

.guess-card {
  width: calc(50% - 10rpx);
  height: 668rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  background-color: #faf8f5;
  border-radius: 16rpx;
  overflow: hidden;
  box-sizing: border-box;
}

/* 图片区固定 3:4 比例 */
.guess-card__cover {
  position: relative;
  width: 100%;
  height: 454rpx;
  flex-shrink: 0;
  overflow: hidden;
  background-color: #ebe6df;
}

.guess-card__cover-img {
  width: 100%;
  height: 100%;
  display: block;
}

.guess-card__cover-placeholder {
  width: 100%;
  height: 100%;
}

.guess-card__cover-placeholder--g1 {
  background-color: #e8e2d8;
}

.guess-card__cover-placeholder--g2 {
  background-color: #e5ddd2;
}

.guess-card__cover-placeholder--g3 {
  background-color: #e0dad0;
}

.guess-card__cover-placeholder--g4 {
  background-color: #ddd6cb;
}

.guess-card__cover-placeholder--g5 {
  background-color: #ede8e0;
}

.guess-card__cover-placeholder--g6 {
  background-color: #e2dbd0;
}

.guess-card__body {
  flex: 1;
  display: flex;
  flex-direction: column;
  height: 214rpx;
  padding: 20rpx 20rpx 24rpx;
  box-sizing: border-box;
}

.guess-card__name {
  height: 80rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #2c2a28;
  line-height: 40rpx;
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.guess-card__desc {
  height: 32rpx;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9a948a;
  line-height: 32rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.guess-card__price-row {
  margin-top: auto;
  height: 42rpx;
  display: flex;
  flex-direction: row;
  align-items: flex-end;
}

.guess-card__price {
  font-size: 30rpx;
  font-weight: 500;
  color: #2c2a28;
  letter-spacing: 1rpx;
  line-height: 1.2;
}
